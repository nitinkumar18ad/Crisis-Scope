{
  "framework": null,
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "cd ../.. && pnpm run build:dashboard",
  "outputDirectory": "dist/public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://crisis-scope-api-server.vercel.app/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
