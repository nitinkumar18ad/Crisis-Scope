{
  "version": 2,
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "cd ../.. && pnpm build:api",
  "builds": [
    {
      "src": "dist/index.mjs",
      "use": "@vercel/node@3",
      "config": { "nodeVersion": "22.x" }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/index.mjs"
    }
  ]
}