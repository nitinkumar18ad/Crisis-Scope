{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev:dashboard": "pnpm --filter @workspace/crisis-dashboard run dev",
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "build:dashboard": "pnpm --filter @workspace/crisis-dashboard run build",
    "build:api": "pnpm --filter @workspace/api-server run build",
    "start": "pnpm --filter @workspace/api-server run start",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "devDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.62.2",
    "@types/node": "catalog:",
    "dotenv": "^17.4.2",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
